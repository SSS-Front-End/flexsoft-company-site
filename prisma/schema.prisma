generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id Int @id @default(autoincrement())

  title_ru String
  title_en String
  title_uz String

  description_ru String
  description_en String
  description_uz String

  image String

  createdAt DateTime @default(now())
}